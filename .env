# LLM API 配置（如使用 OpenAI 兼容接口）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini

# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=danci

# 数据库模式（true=SQLite本地模式，无需MySQL；false=MySQL）
USE_SQLITE=true

# 服务配置
API_PORT=8000
DEBUG=true
